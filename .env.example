# Copy this file to .env and fill in real values. Never commit the real .env file.

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Shared secret between Django and the Telegram bot service.
BOT_API_KEY=replace-with-a-long-random-string

# Database (defaults to sqlite if left blank — fine for development).
# For production, use PostgreSQL:
DB_ENGINE=django.db.backends.postgresql
DB_NAME=trustbot
DB_USER=trustbot
DB_PASSWORD=replace-with-a-strong-password
DB_HOST=localhost
DB_PORT=5432

# Telegram bot token from @BotFather
BOT_TOKEN=replace-with-bot-token-from-botfather

# Zarinpal merchant id — get a free sandbox one at https://next.zarinpal.com for testing.
ZARINPAL_MERCHANT_ID=replace-with-zarinpal-merchant-id

# Base URL where Django API is reachable from the bot service
API_BASE_URL=http://127.0.0.1:8000/api/v1

# Base URL for the public verification page (served by this same Django app at /p/<slug>/).
# In production, point this at your real domain, e.g. https://yourdomain.com/p
PUBLIC_LINK_BASE=http://127.0.0.1:8000/p
